# Copia este archivo a server/.env y rellena los valores.
DATABASE_URL="postgresql://usuario:password@localhost:5432/nodo_vida?schema=public"
JWT_SECRET="cambia-esto-por-una-cadena-larga-y-secreta"
PORT=3000
NODE_ENV=development

# IA (Silvia personal + captura asistida). Opcional: sin esto la IA queda deshabilitada.
ANTHROPIC_API_KEY=""

# Precios de inversiones — Finnhub free tier (https://finnhub.io). Opcional.
FINNHUB_API_KEY=""

# CORS — vacío = solo mismo origen (despliegue de un solo servicio).
ALLOWED_ORIGINS=""

# Recordatorios (Web Push). Genera el par con: npx web-push generate-vapid-keys
# Vacío = los recordatorios push quedan deshabilitados (la app sigue funcionando).
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:tu-correo@ejemplo.com"

# PIN inicial del usuario sembrado (cámbialo desde la app).
SEED_PIN="1234"
